{
  "//": "pravartak: template=package.json.template version={{PRAVARTAK_VERSION}} generated={{SCAFFOLD_DATE}}",
  "//1": "Root workspace package.json for {{PROJECT_NAME}}. For a brownfield project that already",
  "//2": "has one, do NOT overwrite — merge the scripts + devDependencies + packageManager below",
  "//3": "(ownership: project, upgrade_strategy: diff-and-prompt). The gate depends on the lint /",
  "//4": "typecheck / test scripts existing per-package and on these root devDependencies.",
  "name": "{{PROJECT_NAME_SLUG}}",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">={{LANGUAGE_VERSION}}"
  },
  "scripts": {
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "build": "turbo run build",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@vitest/coverage-v8": "^2.1.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "//scripts-note": "Each package/app must define its own lint/typecheck/test scripts so turbo has tasks to run. The gate FAILS (GAN-34) if turbo runs 0 tasks for lint or typecheck. Per-package convention: lint='biome check src', typecheck='tsc --noEmit', test='vitest run --coverage'."
}
